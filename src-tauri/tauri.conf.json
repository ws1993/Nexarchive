{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexArchive",
  "version": "0.1.2",
  "identifier": "com.nexarchive.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexArchive",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "minWidth": 1080,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWS197B0BS1t5ryVHWCGnApvKxBZGf9mIu+TllWfySaMngYtqEy5HY+R",
      "endpoints": [
        "https://github.com/ws1993/Nexarchive/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
